# ──────────────────────────────────────────────
# DRI Multi-Agent System — Configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# === LLM ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Model used by the root agent (CEO) — most capable recommended
ROOT_MODEL=claude-sonnet-4-6
# Default model for all other agents
DEFAULT_MODEL=claude-sonnet-4-6
# Max tokens per single LLM response
MAX_TOKENS_PER_RESPONSE=8192

# === Budget ===
# Total token budget per user session (input + output combined)
BUDGET_MAX_TOKENS_PER_SESSION=2000000
# Fraction of parent's budget allocated to each child by default (0.0 to 1.0)
BUDGET_CHILD_DEFAULT_SHARE=0.4
# When remaining budget drops below this fraction, child alerts parent
BUDGET_WARNING_THRESHOLD=0.2

# === Tools (optional) ===
# At least one search API key is needed for web_search tool
TAVILY_API_KEY=
BRAVE_API_KEY=

# === Storage ===
# SQLite (default, local). Swap to postgresql+asyncpg://user:pass@host/db for production.
DATABASE_URL=sqlite+aiosqlite:///./dri_company.db

# === Workspace ===
# Directory where agents read/write files
WORKSPACE_DIR=./workspace

# === Orchestration ===
# Maximum number of agents running concurrently across the entire system
MAX_CONCURRENT_AGENTS=20
# Maximum depth of the agent hierarchy tree
MAX_SPAWN_DEPTH=10
# Seconds before a single agent task is considered timed out
AGENT_TIMEOUT_SECONDS=300
